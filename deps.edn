{:paths ["src"]
 ;; junbi (準備) — etzhayyim reserve treasury actor (ADR-2607021800).
 ;; R1: langgraph-clj StateGraph (TreasuryActor) + kotoba-lang/banking
 ;; double-entry + kotoba-lang/base-l2 read-only Base observation — all
 ;; :local/root, the 3-actor 同型 deps shape (itonami/robotaxi/gftd-talent).
 ;; The core stays pure .cljc; chain reads go through base-l2's injected
 ;; ITransport (kotoba read+verify posture — no keys, no signing here).
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/banking
        {:local/root "../../kotoba-lang/banking"}
        io.github.kotoba-lang/base-l2
        {:local/root "../../kotoba-lang/base-l2"}}
 :aliases
 {:dev  {:override-deps
         {io.github.com-junkawasaki/langchain-clj
          {:local/root "../../kotoba-lang/langchain"}}}
  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
